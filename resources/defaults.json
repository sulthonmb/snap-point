  "shortcuts": [
    { "action": "left_half",            "key": "left",  "modifiers": ["ctrl","opt"],       "enabled": true },
    { "action": "right_half",           "key": "right", "modifiers": ["ctrl","opt"],       "enabled": true },
    { "action": "top_half",             "key": "up",    "modifiers": ["ctrl","opt"],       "enabled": true },
    { "action": "bottom_half",          "key": "down",  "modifiers": ["ctrl","opt"],       "enabled": true },
    { "action": "top_left_quarter",     "key": "u",     "modifiers": ["ctrl","opt"],       "enabled": true },
    { "action": "top_right_quarter",    "key": "i",     "modifiers": ["ctrl","opt"],       "enabled": true },
    { "action": "bottom_left_quarter",  "key": "j",     "modifiers": ["ctrl","opt"],       "enabled": true },
    { "action": "bottom_right_quarter", "key": "k",     "modifiers": ["ctrl","opt"],       "enabled": true },
    { "action": "first_third",          "key": "d",     "modifiers": ["ctrl","opt"],       "enabled": true },
    { "action": "center_third",         "key": "f",     "modifiers": ["ctrl","opt"],       "enabled": true },
    { "action": "last_third",           "key": "g",     "modifiers": ["ctrl","opt"],       "enabled": true },
    { "action": "top_third",            "key": "up",    "modifiers": ["ctrl","opt","shift"],"enabled": true },
    { "action": "middle_third",         "key": "right", "modifiers": ["ctrl","opt","shift"],"enabled": true },
    { "action": "bottom_third",         "key": "down",  "modifiers": ["ctrl","opt","shift"],"enabled": true },
    { "action": "left_two_thirds",      "key": "e",     "modifiers": ["ctrl","opt"],       "enabled": true },
    { "action": "right_two_thirds",     "key": "t",     "modifiers": ["ctrl","opt"],       "enabled": true },
    { "action": "top_two_thirds",       "key": "u",     "modifiers": ["ctrl","opt","shift"],"enabled": true },
    { "action": "bottom_two_thirds",    "key": "j",     "modifiers": ["ctrl","opt","shift"],"enabled": true },
