    { "action": "almost_maximize",      "key": "return","modifiers": ["ctrl","opt"],       "enabled": true },
    { "action": "throw_to_next_display","key": "right", "modifiers": ["ctrl","opt","cmd"], "enabled": true },
    { "action": "throw_to_prev_display","key": "left",  "modifiers": ["ctrl","opt","cmd"], "enabled": true }
